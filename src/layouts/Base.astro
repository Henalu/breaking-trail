---
import '../styles/global.css'
import SearchPalette from '../components/SearchPalette.astro'
import { getCollection } from 'astro:content'
import { CATEGORIA_LABELS } from '../lib/categories'

interface Props {
  title: string
  description: string
  narrow?: boolean
  wide?: boolean
}

const { title, description, narrow = false, wide = false } = Astro.props

const articles = await getCollection('articles')
const slugsConArticulos = [...new Set(articles.map(a => a.data.categoria))]
const categorias = slugsConArticulos
  .map(slug => ({ slug, label: CATEGORIA_LABELS[slug] ?? slug }))
  .sort((a, b) => a.label.localeCompare(b.label))

const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="google-site-verification" content="YMbQ653EAmhsFYnVf2Bt017QSuX2l5GQXuPWj0pD9Bg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{Astro.url.pathname === '/' ? 'Breaking Trail — Referencia técnica ServiceNow en español' : `${title} | Breaking Trail`}</title>
    <link rel="preload" href="/fonts/Geist-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GeistMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-[#0a0a0a] text-gray-100 min-h-screen font-sans antialiased">

    <header class="border-b border-white/[0.06] sticky top-0 z-10 bg-[#0a0a0a]/90 backdrop-blur-sm">
      <div class="max-w-5xl mx-auto px-6">

        <!-- Row 1: Logo + Search + Mobile menu toggle -->
        <div class="flex items-center justify-between h-14 gap-4">
          <a href="/" class="shrink-0 text-sm font-semibold text-white tracking-tight">
            Breaking Trail
          </a>

          <div class="flex items-center gap-3">
            <SearchPalette />
            <button
              id="menu-toggle"
              class="md:hidden shrink-0 text-gray-400 hover:text-white transition-colors p-1 cursor-pointer"
              aria-label="Abrir menú de categorías"
              aria-expanded="false"
              aria-controls="mobile-menu"
            >
              <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
              <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Row 2: Desktop category nav -->
        <div class="hidden md:block relative">
          <nav aria-label="Categorías" class="flex items-center gap-1 overflow-x-auto scrollbar-none pb-2">
            {categorias.map(cat => (
              <a
                href={`/categoria/${cat.slug}`}
                class:list={[
                  'shrink-0 text-xs px-2.5 py-1.5 rounded-md transition-colors',
                  currentPath === `/categoria/${cat.slug}`
                    ? 'text-white bg-white/[0.10]'
                    : 'text-gray-500 hover:text-gray-200 hover:bg-white/[0.06]'
                ]}
                aria-current={currentPath === `/categoria/${cat.slug}` ? 'page' : undefined}
              >
                {cat.label}
              </a>
            ))}
          </nav>
          <div class="absolute right-0 top-0 bottom-2 w-8 bg-gradient-to-l from-[#0a0a0a] to-transparent pointer-events-none" aria-hidden="true"></div>
        </div>

        <!-- Mobile menu -->
        <nav id="mobile-menu" class="hidden md:hidden flex-col pb-3" aria-label="Categorías">
          {categorias.map(cat => (
            <a
              href={`/categoria/${cat.slug}`}
              class:list={[
                'block text-sm px-2 py-2.5 rounded-md transition-colors',
                currentPath === `/categoria/${cat.slug}`
                  ? 'text-white bg-white/[0.08]'
                  : 'text-gray-400 hover:text-white hover:bg-white/[0.06]'
              ]}
              aria-current={currentPath === `/categoria/${cat.slug}` ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

      </div>
    </header>

    <main class:list={[
      'mx-auto px-6 pt-14 pb-20',
      wide ? 'max-w-5xl' : narrow ? 'max-w-[720px]' : 'max-w-[900px]'
    ]}>
      <slot />
    </main>

    <footer class="border-t border-white/[0.06] px-6 py-8 text-center text-gray-500 text-xs font-mono tracking-wide">
      Breaking Trail — Referencia técnica ServiceNow en español
    </footer>

    <script is:inline>
      const toggle = document.getElementById('menu-toggle')
      const menu = document.getElementById('mobile-menu')
      const iconOpen = document.getElementById('icon-open')
      const iconClose = document.getElementById('icon-close')

      toggle.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden')
        menu.classList.toggle('hidden', isOpen)
        menu.classList.toggle('flex', !isOpen)
        iconOpen.classList.toggle('hidden', !isOpen)
        iconClose.classList.toggle('hidden', isOpen)
        toggle.setAttribute('aria-expanded', String(!isOpen))
      })

      document.addEventListener('click', (e) => {
        if (!toggle.contains(e.target) && !menu.contains(e.target)) {
          menu.classList.add('hidden')
          menu.classList.remove('flex')
          iconOpen.classList.remove('hidden')
          iconClose.classList.add('hidden')
          toggle.setAttribute('aria-expanded', 'false')
        }
      })
    </script>

  </body>
</html>
