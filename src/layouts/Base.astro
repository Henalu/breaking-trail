---
import '../styles/global.css'
import Search from '../components/Search.astro'
import { getCollection } from 'astro:content'

interface Props {
  title: string
  description: string
  narrow?: boolean
}

const { title, description, narrow = false } = Astro.props

const LABELS: Record<string, string> = {
  'awa': 'AWA',
  'assignment-engine': 'Assignment Engine',
  'business-rules': 'Business Rules',
  'cmdb': 'CMDB',
  'integraciones': 'Integraciones',
  'transform-maps': 'Transform Maps',
  'ui-actions': 'UI Actions',
  'workspaces': 'Workspaces',
}

const articles = await getCollection('articles')
const slugsConArticulos = [...new Set(articles.map(a => a.data.categoria))]
const categorias = slugsConArticulos
  .map(slug => ({ slug, label: LABELS[slug] ?? slug }))
  .sort((a, b) => a.label.localeCompare(b.label))
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="google-site-verification" content="YMbQ653EAmhsFYnVf2Bt017QSuX2l5GQXuPWj0pD9Bg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Breaking Trail</title>
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
  </head>
  <body class="bg-[#0a0a0a] text-gray-100 min-h-screen font-sans antialiased">

    <header class="border-b border-white/[0.06] sticky top-0 z-10 bg-[#0a0a0a]/90 backdrop-blur-sm">
      <div class="max-w-5xl mx-auto px-6">

        <!-- Fila 1: Logo + Búsqueda -->
        <div class="flex items-center justify-between h-14 gap-6">
          <a href="/" class="shrink-0 text-sm font-semibold text-white tracking-tight">
            Breaking Trail
          </a>
          <Search />
        </div>

        <!-- Fila 2: Categorías -->
        <nav class="flex items-center gap-1 overflow-x-auto scrollbar-none pb-2">
          {categorias.map(cat => (
            <a
              href={`/categoria/${cat.slug}`}
              class="shrink-0 text-xs text-gray-500 hover:text-gray-200 px-2.5 py-1.5 rounded-md hover:bg-white/[0.06] transition-colors"
            >
              {cat.label}
            </a>
          ))}
        </nav>

      </div>
    </header>

    <main class:list={[
      'mx-auto px-6 py-12',
      narrow ? 'max-w-[720px]' : 'max-w-[900px]'
    ]}>
      <slot />
    </main>

    <footer class="border-t border-white/[0.06] px-6 py-8 text-center text-gray-600 text-xs">
      Breaking Trail — Referencia técnica ServiceNow en español
    </footer>

  </body>
</html>
