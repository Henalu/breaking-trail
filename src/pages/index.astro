---
import { getCollection } from 'astro:content'
import Base from '../layouts/Base.astro'
import ArticleCard from '../components/ArticleCard.astro'

const articulos = (await getCollection('articles'))
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
---

<Base title="Inicio" description="Referencia técnica de ServiceNow en español. Problemas reales, soluciones reales.">
  <div data-pagefind-ignore="all">
  <h1 class="text-3xl font-bold mb-2">Breaking Trail</h1>
  <p class="text-gray-400 mb-10">
    Referencia técnica de ServiceNow en español. Problemas reales de producción, soluciones reales con código.
  </p>

  <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-4">
    Artículos publicados ({articulos.length})
  </h2>

  <ul class="space-y-4">
    {articulos.map(articulo => (
      <li>
        <ArticleCard
          slug={articulo.slug}
          title={articulo.data.title}
          description={articulo.data.description}
          categoria={articulo.data.categoria}
          dificultad={articulo.data.dificultad}
          fecha={articulo.data.fecha}
          servicenow_version={articulo.data.servicenow_version}
          resuelto={articulo.data.resuelto}
        />
      </li>
    ))}
  </ul>
  </div>
</Base>
