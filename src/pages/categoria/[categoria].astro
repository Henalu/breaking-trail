---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import ArticleCard from '../../components/ArticleCard.astro'

const LABELS: Record<string, string> = {
  'awa': 'Advanced Work Assignment',
  'assignment-engine': 'Assignment Engine',
  'business-rules': 'Business Rules',
  'cmdb': 'CMDB',
  'integraciones': 'Integraciones',
  'transform-maps': 'Transform Maps',
  'ui-actions': 'UI Actions',
  'workspaces': 'Workspaces',
  'ui-builder': 'UI Builder',
}

export async function getStaticPaths() {
  const articles = await getCollection('articles')
  const categorias = [...new Set(articles.map(a => a.data.categoria))]
  return categorias.map(categoria => ({ params: { categoria } }))
}

const { categoria } = Astro.params as { categoria: string }

const todos = await getCollection('articles')
const articulos = todos
  .filter(a => a.data.categoria === categoria)
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())

const titulo = LABELS[categoria] ?? categoria
---

<Base title={titulo} description={`Artículos de ${titulo} en Breaking Trail — referencia técnica ServiceNow en español.`}>
  <div data-pagefind-ignore="all">
  <nav class="text-sm text-gray-600 mb-8">
    <a href="/" class="hover:text-gray-300 transition-colors">Inicio</a>
    <span class="mx-2">/</span>
    <span>{titulo}</span>
  </nav>

  <h1 class="text-2xl font-semibold text-white mb-1">{titulo}</h1>
  <p class="text-gray-600 text-sm mb-8">{articulos.length} {articulos.length === 1 ? 'artículo' : 'artículos'}</p>

  {articulos.length === 0 ? (
    <p class="text-gray-600 text-sm">Todavía no hay artículos en esta categoría.</p>
  ) : (
    <ul class="space-y-3">
      {articulos.map(articulo => (
        <li>
          <ArticleCard
            slug={articulo.slug}
            title={articulo.data.title}
            description={articulo.data.description}
            categoria={articulo.data.categoria}
            dificultad={articulo.data.dificultad}
            fecha={articulo.data.fecha}
            servicenow_version={articulo.data.servicenow_version}
            resuelto={articulo.data.resuelto}
          />
        </li>
      ))}
    </ul>
  )}
  </div>
</Base>
