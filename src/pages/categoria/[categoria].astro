---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import ArticleCard from '../../components/ArticleCard.astro'
import { CATEGORIA_LABELS } from '../../lib/categories'

export async function getStaticPaths() {
  const articles = await getCollection('articles')
  const categorias = [...new Set(articles.map(a => a.data.categoria))]
  return categorias.map(categoria => ({ params: { categoria } }))
}

const { categoria } = Astro.params as { categoria: string }

const todos = await getCollection('articles')
const articulos = todos
  .filter(a => a.data.categoria === categoria)
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())

const titulo = CATEGORIA_LABELS[categoria] ?? categoria
---

<Base title={titulo} description={`Artículos de ${titulo} en Breaking Trail — referencia técnica ServiceNow en español.`}>
  <div data-pagefind-ignore="all">
  <nav aria-label="Ruta de navegación" class="text-xs font-mono text-gray-600 mb-10 flex items-center gap-1 tracking-wide">
    <a href="/" class="hover:text-gray-400 transition-colors">Inicio</a>
    <span class="mx-1" aria-hidden="true">/</span>
    <span class="text-gray-500" aria-current="page">{titulo}</span>
  </nav>

  <div class="pb-10 border-b border-white/[0.06] mb-10">
    <p class="text-xs font-mono text-blue-400/60 tracking-[0.15em] uppercase mb-4">
      ServiceNow · En español
    </p>
    <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight leading-[1.1] mb-2">{titulo}</h1>
    <p class="text-xs font-mono text-gray-600 mt-3">{articulos.length} {articulos.length === 1 ? 'artículo' : 'artículos'}</p>
  </div>

  {articulos.length === 0 ? (
    <div class="text-center py-12">
      <p class="text-gray-500 text-sm mb-4">Todavía no hay artículos en esta categoría.</p>
      <a href="/" class="text-blue-400 hover:text-blue-300 transition-colors text-sm">← Volver al inicio</a>
    </div>
  ) : (
    <ul class="space-y-3">
      {articulos.map(articulo => (
        <li>
          <ArticleCard
            slug={articulo.slug}
            title={articulo.data.title}
            description={articulo.data.description}
            categoria={articulo.data.categoria}
            dificultad={articulo.data.dificultad}
            fecha={articulo.data.fecha}
            servicenow_version={articulo.data.servicenow_version}
            resuelto={articulo.data.resuelto}
          />
        </li>
      ))}
    </ul>
  )}
  </div>
</Base>
