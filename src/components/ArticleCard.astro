---
interface Props {
  slug: string
  title: string
  description: string
  categoria: string
  dificultad: string
  fecha: Date
  servicenow_version: string[]
  resuelto: boolean
}

const { slug, title, description, categoria, dificultad, fecha, servicenow_version, resuelto } = Astro.props

const categoriaLabel: Record<string, string> = {
  'awa': 'Advanced Work Assignment',
  'cmdb': 'CMDB',
  'assignment-engine': 'Assignment Engine',
  'integraciones': 'Integraciones',
  'business-rules': 'Business Rules',
  'transform-maps': 'Transform Maps',
  'ui-actions': 'UI Actions',
}

const dificultadLabel: Record<string, string> = {
  basico: 'Básico',
  intermedio: 'Intermedio',
  avanzado: 'Avanzado',
}

const dificultadColor: Record<string, string> = {
  basico: 'text-gray-500',
  intermedio: 'text-gray-400',
  avanzado: 'text-gray-300',
}
---

<a
  href={`/articulos/${slug}`}
  class="block p-5 rounded-lg border border-white/[0.07] hover:border-white/20 hover:bg-white/[0.03] hover:-translate-y-px transition-all duration-150 group"
>
  <div class="flex items-center gap-2 mb-2">
    <span class="text-xs text-gray-600">{categoriaLabel[categoria] ?? categoria}</span>
    <span class="text-gray-700">·</span>
    <span class={`text-xs font-medium ${dificultadColor[dificultad]}`}>
      {dificultadLabel[dificultad]}
    </span>
    {!resuelto && (
      <span class="text-xs text-orange-400">· Sin solución completa</span>
    )}
  </div>
  <h2 class="text-base font-semibold text-gray-100 group-hover:text-white transition-colors mb-1.5">
    {title}
  </h2>
  <p class="text-gray-500 text-sm line-clamp-2 leading-relaxed">{description}</p>
  <p class="text-gray-700 text-xs mt-3">
    {fecha.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
    · {servicenow_version.join(', ')}
  </p>
</a>
