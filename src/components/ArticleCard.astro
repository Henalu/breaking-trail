---
import { CATEGORIA_LABELS, DIFICULTAD_LABELS, DIFICULTAD_COLORS } from '../lib/categories'

interface Props {
  slug: string
  title: string
  description: string
  categoria: string
  dificultad: string
  fecha: Date
  servicenow_version: string[]
  resuelto: boolean
}

const { slug, title, description, categoria, dificultad, fecha, servicenow_version, resuelto } = Astro.props
---

<a
  href={`/articulos/${slug}`}
  class="flex flex-col p-5 rounded-lg border border-white/[0.07] hover:border-white/[0.16] hover:bg-white/[0.03] hover:-translate-y-px active:translate-y-0 active:bg-white/[0.04] transition-[border-color,background-color,transform,color] duration-150 group h-full"
>
  <!-- Metadata superior: categoría + dificultad -->
  <div class="flex items-center gap-2 mb-3 flex-wrap">
    <span class="text-xs font-mono text-gray-600 uppercase tracking-[0.08em]">
      {CATEGORIA_LABELS[categoria] ?? categoria}
    </span>
    <span class="text-gray-700" aria-hidden="true">·</span>
    <span class={`text-xs font-medium px-1.5 py-0.5 rounded ${DIFICULTAD_COLORS[dificultad]}`}>
      {DIFICULTAD_LABELS[dificultad]}
    </span>
    {!resuelto && (
      <span class="text-xs text-orange-400">Sin solución completa</span>
    )}
  </div>

  <!-- Título -->
  <h2 class="text-base font-semibold text-gray-100 group-hover:text-white transition-colors mb-2 leading-snug">
    {title}
  </h2>

  <!-- Descripción -->
  <p class="text-gray-500 text-sm line-clamp-2 leading-relaxed mb-4 flex-1">{description}</p>

  <!-- Metadata inferior: fecha + versiones en mono -->
  <p class="text-xs font-mono text-gray-600 tabular-nums mt-auto">
    {fecha.toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
    <span aria-hidden="true"> · </span>
    {servicenow_version.join(', ')}
  </p>
</a>
