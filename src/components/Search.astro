<!--
  Widget Pagefind directo en el nav — UN SOLO INPUT, sin trigger.
  El backdrop se teleporta al <body> para evitar el stacking context del header.
-->
<div id="search-container" class="relative w-56 xl:w-72">
  <div id="pagefind-search"></div>
</div>

<div id="search-backdrop" class="hidden fixed inset-0 z-[5] bg-black/50"></div>

<script>
  // Teleportar backdrop al <body> (escapa el stacking context del header z-10)
  const backdrop = document.getElementById('search-backdrop')
  if (backdrop) { backdrop.style.display = ''; document.body.appendChild(backdrop) }

  function getInput(): HTMLInputElement | null {
    return document.querySelector('.pagefind-ui__search-input')
  }

  function openSearch() {
    backdrop?.classList.remove('hidden')
  }

  function closeSearch() {
    backdrop?.classList.add('hidden')
    // Limpiar búsqueda al cerrar
    const inp = getInput()
    if (inp && inp.value) {
      inp.value = ''
      inp.dispatchEvent(new Event('input', { bubbles: true }))
    }
  }

  // Abrir al hacer focus en el input de Pagefind
  document.addEventListener('focusin', (e) => {
    if ((e.target as HTMLElement)?.classList.contains('pagefind-ui__search-input')) {
      openSearch()
    }
  })

  // Cerrar al hacer clic en el backdrop
  backdrop?.addEventListener('click', closeSearch)

  // Atajos de teclado
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeSearch()
      getInput()?.blur()
    }
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      getInput()?.focus()
    }
  })

  // Inicializar Pagefind
  window.addEventListener('DOMContentLoaded', () => {
    if (!document.getElementById('pagefind-search')) return
    // @ts-ignore
    new PagefindUI({
      element: '#pagefind-search',
      showSubResults: false,
      showImages: false,
      translations: {
        placeholder: 'Buscar artículos...',
        zero_results: 'Sin resultados para "[SEARCH_TERM]"',
      },
    })
  })
</script>
